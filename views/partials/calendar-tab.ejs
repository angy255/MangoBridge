<div id="calendar" class="tab-content">
    <div class="chat-container">
        <div class="calendar-header">
            <h2 style="background-color: #3d348b; color:white; padding: 14px; font-size: 24px; border-radius: 24px; max-width: fit-content;">Event Calendar</h2>
            <div>
                <button class="btn btn-secondary" id="prevMonthBtn">◀ Prev</button>
                <span id="currentMonth" style="margin: 0 15px; font-weight: 600; color:#F35B04; text-shadow: 2px 2px 2px white;"></span>
                <button class="btn btn-secondary" id="nextMonthBtn">Next ▶</button>
            </div>
        </div>
        <div class="calendar-wrapper">
            <div class="calendar-container">
                <div class="calendar-grid" id="calendarGrid"></div>
            </div>
            <div class="day-taskbar" id="dayTaskbar">
                <div style="font-weight: bold; margin-bottom: 15px; padding-bottom: 10px; border-bottom: 2px solid #667eea;">
                    Select a day
                </div>
                <p style="text-align: center; color: #999;">Click on a day to see events</p>
            </div>
        </div>
    </div>
</div>

<!-- Event Modal -->
<div class="modal" id="eventModal">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Events for <span id="modalDate"></span></h3>
            <button class="close-modal" onclick="closeEventModal()">×</button>
        </div>

        <form id="eventForm">
            <div class="form-group">
                <label class="form-label">Event Title</label>
                <input type="text" class="form-input" id="eventTitle" placeholder="Enter event title" required>
            </div>
            <div class="form-group">
                <label class="form-label">Time</label>
                <input type="time" class="form-input" id="eventTime" required>
            </div>
            <div class="form-group">
                <label class="form-label">Location (Optional)</label>
                <input type="text" class="form-input" id="eventLocation" placeholder="Enter event location">
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 20px;">
                ➕ Add Event
            </button>
        </form>

        <div class="event-list" id="eventList"></div>
    </div>
</div>