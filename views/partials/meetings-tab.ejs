<div id="meetings" class="tab-content">
    <div class="chat-container">
        <div class="chat-header">
            <h2>🎙️ Record & Summarize Meetings</h2>
        </div>

        <div class="recording-container">
            <div class="recording-controls">
                <button class="btn btn-danger" id="meetingRecordBtn">
                    🎤 Start Recording
                </button>
                <select class="form-select" id="meetingSourceLang" style="max-width: 200px;">
                    <!-- <option value="en">English</option> -->
                    <option value="es">Spanish</option>
                    <option value="fr">French</option>
                    <option value="de">German</option>
                    <option value="zh">Chinese</option>
                    <option value="ja">Japanese</option>
                    <option value="pt">Portuguese</option>
                    <option value="it">Italian</option>
                    <option value="nl">Dutch</option>
                    <option value="pl">Polish</option>
                    <option value="ru">Russian</option>
                    <option value="ko">Korean</option>
                    <option value="tr">Turkish</option>
                </select>
                <select class="form-select" id="meetingTargetLang" style="max-width: 200px;">
                    <option value="en">English</option>
                    <!-- <option value="es">Spanish</option>
                    <option value="fr">French</option>
                    <option value="de">German</option>
                    <option value="zh">Chinese</option>
                    <option value="ja">Japanese</option>
                    <option value="pt">Portuguese</option>
                    <option value="it">Italian</option>
                    <option value="nl">Dutch</option>
                    <option value="pl">Polish</option>
                    <option value="ru">Russian</option>
                    <option value="ko">Korean</option>
                    <option value="tr">Turkish</option> -->
                </select>
            </div>

            <div class="transcript-box" id="meetingTranscript">
                <p style="color: #999;">Transcript will appear here...</p>
            </div>

            <div id="editTranscriptBtnContainer" style="display: none; margin-bottom: 10px;">
                <button class="btn btn-secondary" id="editTranscriptBtn">
                    ✏️ Edit Transcript
                </button>
            </div>

            <div class="button-row">
                <!-- <button class="btn btn-info" id="previewTranslationBtn">
                    👁️ Preview Translation
                </button> -->
                <button class="btn btn-primary" id="translateTranscriptBtn">
                    🌐 Translate Transcript
                </button>
                <button class="btn btn-success" id="summarizeBtn">
                    📝 Generate Summary
                </button>
            </div>

            <div class="translation-preview-box" id="translationPreviewBox" style="display: none; background: #e3f2fd; padding: 20px; border-radius: 10px; margin: 20px 0; border: 2px solid #2196f3;">
                <h3 style="color: #1976d2; margin-bottom: 15px;">Translation Preview</h3>
                <div id="translationPreviewContent" style="line-height: 1.6;"></div>
            </div>

            <div class="summary-box" id="meetingSummary" style="display: none;">
                <h3>📋 Meeting Summary</h3>
                <div id="summaryContent"></div>
            </div>
        </div>
    </div>
</div>