<div id="archived" class="tab-content">
    <div class="chat-container">
        <div class="chat-header">
            <h2>📁 Archived Messages</h2>
            <button class="btn btn-danger" id="clearArchivedBtn">
                🗑️ Clear Archived
            </button>
        </div>

        <div class="message-list scrollable" id="archivedMessageList"></div>

        <div class="empty-state" id="archivedEmptyState" style="display: none;">
            <div class="empty-state-icon">📂</div>
            <h3>No archived messages</h3>
            <p>Archived messages will appear here</p>
        </div>
    </div>
</div>