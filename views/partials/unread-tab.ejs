<div id="unread" class="tab-content">
    <div class="chat-container">
        <div class="chat-header">
            <h2>📬 Unread Messages</h2>
            <button class="btn btn-success" id="markAllReadBtn">
                ✓ Mark All as Read
            </button>
        </div>

        <div class="message-list scrollable" id="unreadMessageList"></div>

        <div class="empty-state" id="unreadEmptyState" style="display: none;">
            <div class="empty-state-icon">✅</div>
            <h3>All caught up!</h3>
            <p>No unread messages</p>
        </div>
    </div>
</div>