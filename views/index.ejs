<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MangoBridge</title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/navigation.css">
    <link rel="stylesheet" href="/css/messages.css">
    <link rel="stylesheet" href="/css/calendar.css">
    <link rel="stylesheet" href="/css/forms.css">
    <link rel="stylesheet" href="/css/chatgroups.css">
    <link rel="stylesheet" href="/css/groupchats.css">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='0.9em' font-size='90'>🥭</text></svg>">
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container">
        <%- include('partials/home-tab') %>
        <%- include('partials/group-chats-tab') %>
        <%- include('partials/archived-tab') %>
        <%- include('partials/calendar-tab') %>
        <%- include('partials/meetings-tab') %>
        <%- include('partials/summaries-tab') %>
    </div>

    <!-- event modal -->
    <div class="modal" id="eventModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Events for <span id="modalDate"></span></h3>
                <button class="close-modal" onclick="closeEventModal()">×</button>
            </div>

            <form id="eventForm">
                <div class="form-group">
                    <label class="form-label">Event Title</label>
                    <input type="text" class="form-input" id="eventTitle" placeholder="Enter event title" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Time</label>
                    <input type="time" class="form-input" id="eventTime" required>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;">
                    ➕ Add Event
                </button>
            </form>

            <div class="event-list" id="eventList"></div>
        </div>
    </div>

    <!-- define currentUser BEFORE loading any scripts -->
    <script>
        const currentUser = <%- JSON.stringify(user) %>;
    </script>
    
    <!-- load scripts in correct order: utilities first, then features, then app initialization -->
    <script src="/js/notifications.js"></script>
    <script src="/js/messages.js"></script>
    <script src="/js/unreadMessages.js"></script>
    <script src="/js/calendar.js"></script>
    <script src="/js/meetings.js"></script>
    <script src="/js/summaries.js"></script>
    <script src="/js/app.js"></script>
</body>
</html>