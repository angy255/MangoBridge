<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- link to CSS in public folder -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <!-- main container -->
    <div class="container">
        <!-- header section with title and description -->
        <div class="header">
            <h1>🌍 <%= title %></h1>
            <p>Communicate naturally across languages with AI-powered cultural context</p>
            <div class="badges">
                <span class="badge badge-success">AI-Powered</span>
                <span class="badge badge-info">Context-Aware</span>
                <% if (nodeEnv === 'development') { %>
                    <span class="badge" style="background: #ffc107;">Development Mode</span>
                <% } %>
            </div>
        </div>

        <!-- main chat container -->
        <div class="chat-container">
            <!-- chat header with clear all button -->
            <div class="chat-header">
                <h2>Team Messages</h2>
                <button class="btn btn-danger" onclick="clearAllMessages()">
                    🗑️ Clear All
                </button>
            </div>

            <!--mMessage list section -->
            <div class="message-list" id="messageList">
                <!-- messages go here -->
                </div>

                <!-- empty state shown when no messages, outside messageList -->
                <div class="empty-state" id="emptyState" style="display: none;">
                    <div class="empty-state-icon">💬</div>
                    <h3>No messages yet</h3>
                    <p>Start a conversation with your team!</p>
                </div>

            <!-- loading indicator shown during translation -->
            <div class="loading" id="loadingIndicator">
                <div class="spinner"></div>
                <p class="loading-text">AI is translating with cultural context...</p>
            </div>

            <!-- message form container -->
            <div class="form-container">
                <form id="messageForm">
                    <!-- First row: Name and language selectors -->
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Your Name</label>
                            <input type="text" class="form-input" id="userName" required placeholder="Enter your name">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Source Language</label>
                            <select class="form-select" id="sourceLang" required>
                                <option value="en">English</option>
                                <option value="es">Spanish</option>
                                <option value="fr">French</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Translate To</label>
                            <select class="form-select" id="targetLang" required>
                                <option value="es">Spanish</option>
                                <option value="fr">French</option>
                                <option value="en">English</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Second row: Message text area -->
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Message</label>
                            <textarea class="form-textarea" id="messageText" required placeholder="Type your message... (Try idioms like 'I'm in a pickle' or 'break a leg')"></textarea>
                        </div>
                    </div>
                    
                    <!-- submit button -->
                    <button type="submit" class="btn btn-primary">
                        ✉️ Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- link to JavaScript in public folder -->
    <script src="/js/app.js"></script>
</body>
</html>